{{> menu-navbar }}

<section class="section">
  <div class="box">
    <h1 class="title">Edit Workout</h1>

    <form action="/workout/{{workout._id}}/edit" method="POST">
      <div class="field">
        <label class="label">Workout Title</label>
        <div class="control">
          <input
            class="input"
            type="text"
            name="title"
            value="{{workout.title}}"
            required
          >
        </div>
      </div>

      <button class="button is-success">
        Save Changes
      </button>
    </form>
  </div>
</section>