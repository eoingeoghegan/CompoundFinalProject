<h1 class="title">Tracked Workouts</h1>

{{#each trackedWorkouts}}
  <div class="box">
     {{workoutTitle}} <br>
      <small>{{timestamp}}</small>
    </h2>

    <table class="table is-fullwidth">
      <thead>
        <tr>
          <th>Exercise</th>
          <th>Equipment</th>
          <th>Weight</th>
          <th>Sets</th>
          <th>Reps</th>
        </tr>
      </thead>
      <tbody>
        {{#each exercises}}
          <tr>
            <td>{{title}}</td>
            <td>{{equipment}}</td>
            <td>{{weight}}</td>
            <td>{{sets}}</td>
            <td>{{reps}}</td>
          </tr>
        {{/each}}
      </tbody>
    </table>
  </div>
{{/each}}