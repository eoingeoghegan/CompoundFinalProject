{{!-- This will displays any errors in the broweser in a list. Added to layout.hbs 
Errors come from vaildation while entering information in the forms. See Validation in signup, login,
add workout and add exercises. --}}

{{#if errors}}
  <div class="box content">
    <p> There was a problem... </p>
    <ul>
      {{#each errors}}
        <li>{{message}}</li>
      {{/each}}
    </ul>
  </div>
{{/if}}
