<h1 class="title">{{title}}</h1>

<h2>Registered Users</h2>
<table class="table is-fullwidth">
  <thead>
    <tr>
      <th>First Name</th>
      <th>Last Name</th>
      <th>Email</th>
    </tr>
  </thead>
  <tbody>
    {{#each users}}
      <tr>
        <td>{{firstName}}</td>
        <td>{{lastName}}</td>
        <td>{{email}}</td>
      </tr>
    {{/each}}
  </tbody>
</table>